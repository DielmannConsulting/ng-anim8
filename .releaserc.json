{
  "branches": [
    "main",
    { "name": "next", "prerelease": true },
    { "name": "beta", "prerelease": true }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      { "preset": "angular" }
    ],
    [
      "@semantic-release/release-notes-generator",
      { "preset": "angular" }
    ],
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/npm",
      { "npmPublish": false }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/set-version.mjs ${nextRelease.version} && pnpm ng build ng-anim8",
        "publishCmd": "pnpm publish dist/ng-anim8 --no-git-checks --access public"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json", "projects/ng-anim8/package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
